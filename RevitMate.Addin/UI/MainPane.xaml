<UserControl x:Class="RevitMate.Addin.UI.MainPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:RevitMate.Resources;assembly=RevitMate.Resources"
             xmlns:local="clr-namespace:RevitMate.Addin.UI"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             FontFamily="Segoe UI"
             FontSize="13"
             Background="#F7F7F8"
             d:DesignHeight="600" d:DesignWidth="380">

    <UserControl.Resources>
        <local:RoleToAlignmentConverter x:Key="RoleToAlignment"/>
        <local:RoleToBubbleBrushConverter x:Key="RoleToBubble"/>
        <local:RoleToBorderBrushConverter x:Key="RoleToBorder"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0E7C7B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CC9C8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="BorderBrush" Value="#D0D0D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type local:ChatMessage}">
            <Grid HorizontalAlignment="{Binding Role, Converter={StaticResource RoleToAlignment}}"
                  Margin="0,4">
                <Border x:Name="Bubble"
                        CornerRadius="10"
                        Padding="10,7"
                        MaxWidth="300"
                        Background="{Binding Role, Converter={StaticResource RoleToBubble}}"
                        BorderBrush="{Binding Role, Converter={StaticResource RoleToBorder}}"
                        BorderThickness="1">
                    <TextBlock x:Name="BubbleText"
                               Text="{Binding Text}"
                               TextWrapping="Wrap"
                               Foreground="#222"/>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="{x:Static local:Role.Action}">
                    <Setter TargetName="Bubble" Property="Background" Value="#F3EEFF"/>
                    <Setter TargetName="Bubble" Property="BorderBrush" Value="#9370DB"/>
                    <Setter TargetName="Bubble" Property="BorderThickness" Value="3,0,0,0"/>
                    <Setter TargetName="Bubble" Property="CornerRadius" Value="0,4,4,0"/>
                    <Setter TargetName="BubbleText" Property="FontStyle" Value="Italic"/>
                    <Setter TargetName="BubbleText" Property="Foreground" Value="#5A3E8A"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E5"
                BorderThickness="0,0,0,1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{x:Static res:Strings.PanelTitle}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#222"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Ellipse Width="8" Height="8"
                                 Fill="#0E7C7B"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText"
                                   Text="{x:Static res:Strings.StatusReady}"
                                   FontSize="11"
                                   Foreground="#666"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           x:Name="ModelText"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#888"/>
            </Grid>
        </Border>

        <!-- Loading indicator -->
        <ProgressBar Grid.Row="1"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                     Foreground="#0E7C7B"
                     Background="Transparent"
                     BorderThickness="0"/>

        <!-- Conversation -->
        <ScrollViewer Grid.Row="2"
                      x:Name="ConversationScroll"
                      VerticalScrollBarVisibility="Auto"
                      Padding="2,8"
                      Background="Transparent">
            <ItemsControl ItemsSource="{Binding Messages}"
                          ItemTemplate="{StaticResource MessageTemplate}"/>
        </ScrollViewer>

        <!-- Suggestion chips -->
        <ItemsControl Grid.Row="3" Margin="0,4,0,6">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <Button Style="{StaticResource ChipButton}"
                    Content="{x:Static res:Strings.Suggestion1}"
                    Command="{Binding UseSuggestionCommand}"
                    CommandParameter="{x:Static res:Strings.Suggestion1}"/>
            <Button Style="{StaticResource ChipButton}"
                    Content="{x:Static res:Strings.Suggestion2}"
                    Command="{Binding UseSuggestionCommand}"
                    CommandParameter="{x:Static res:Strings.Suggestion2}"/>
            <Button Style="{StaticResource ChipButton}"
                    Content="{x:Static res:Strings.Suggestion3}"
                    Command="{Binding UseSuggestionCommand}"
                    CommandParameter="{x:Static res:Strings.Suggestion3}"/>
        </ItemsControl>

        <!-- Selection snapshot pill -->
        <Border Grid.Row="4"
                Margin="0,0,0,4"
                HorizontalAlignment="Left"
                Visibility="{Binding HasSelectionSnapshot, Converter={StaticResource BoolToVisibility}}">
            <Border Background="#0E7C7B"
                    CornerRadius="10"
                    Padding="8,3">
                <TextBlock Text="{Binding SelectionSnapshotSummary}"
                           Foreground="White"
                           FontSize="11"/>
            </Border>
        </Border>

        <!-- Input row -->
        <Grid Grid.Row="5" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D0D0D5"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <TextBox x:Name="InputBox"
                             Text="{Binding CurrentInput, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="8,6"
                             MinHeight="32"
                             MaxHeight="120"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             KeyDown="OnInputKeyDown"/>
                    <TextBlock IsHitTestVisible="False"
                               Text="{x:Static res:Strings.InputPlaceholder}"
                               Foreground="#A0A0A5"
                               Margin="10,6,0,0"
                               VerticalAlignment="Top">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=InputBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Content="{x:Static res:Strings.NewConversationButton}"
                    Command="{Binding NewConversationCommand}"
                    Margin="6,0,0,0"/>

            <Button Grid.Column="2"
                    Style="{StaticResource PrimaryButton}"
                    Content="{x:Static res:Strings.SendButton}"
                    Command="{Binding SendCommand}"
                    Margin="6,0,0,0"/>
        </Grid>
    </Grid>
</UserControl>
